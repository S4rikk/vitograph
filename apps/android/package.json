{
  "name": "vitograph-android",
  "version": "0.1.0",
  "private": true,
  "description": "Vitograph Android app (Capacitor shell)",
  "scripts": {
    "cap:init": "npx cap add android",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:run": "npx cap run android",
    "cap:build:debug": "npx cap sync android && cd android && .\\gradlew.bat assembleDebug",
    "cap:build:release": "npx cap sync android && cd android && .\\gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  }
}
