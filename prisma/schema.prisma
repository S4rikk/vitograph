// ═══════════════════════════════════════════════════════════════════════
// VITOGRAPH — Prisma Schema (PostgreSQL / Supabase)
// ═══════════════════════════════════════════════════════════════════════
//
// Maps health-core.ts (25+ TypeScript entities) to PostgreSQL tables.
// Existing SQL tables (profiles, biomarkers, etc.) are mirrored with @@map.
//
// INDEXING STRATEGY:
//   • Every FK column gets an explicit @@index (PG does NOT auto-index FKs).
//   • Time-series tables (CgmReading, HrvReading, EnvironmentReading,
//     SleepSession) have composite @@index([userId, recordedAt/date])
//     for fast user-scoped temporal range queries.
//   • Unique business keys use @@unique (e.g., one norm per user+biomarker).
//   • JSONB columns rely on native GIN indexes via post-migration raw SQL.
//
// ═══════════════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

